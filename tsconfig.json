{
  "compilerOptions": {
    /* ================== BASE ================== */
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node16",

    /* ================== PATHS ================== */
    "baseUrl": ".",
    "paths": {
      "@config/*": ["src/config/*"],
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@docs/*": ["src/docs/*"]
    },

    /* ================== OUTPUT ================== */
    "outDir": "./build",
    "rootDir": ".",

    /* ================== INTEROP ================== */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* ================== STRICT ================== */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,

    /* ================== TYPES ================== */
    "typeRoots": ["./@types", "./node_modules/@types"],
    "types": ["node", "express", "jest"],

    /* ================== DECORATORS ================== */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* ================== PERFORMANCE ================== */
    "skipLibCheck": true
  },

  /* ================== INCLUDE / EXCLUDE ================== */
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "build"]
}
